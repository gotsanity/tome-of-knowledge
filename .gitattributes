# Auto-detect text files and normalize line endings to LF in the repo
* text=auto eol=lf

# Source files — always LF
*.ts       text eol=lf
*.tsx      text eol=lf
*.js       text eol=lf
*.jsx      text eol=lf
*.mjs      text eol=lf
*.cjs      text eol=lf
*.json     text eol=lf
*.css      text eol=lf
*.scss     text eol=lf
*.html     text eol=lf
*.md       text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.toml     text eol=lf

# Shell and Docker must be LF (runs on Linux containers)
*.sh              text eol=lf
Dockerfile        text eol=lf
Dockerfile.*      text eol=lf
.dockerignore     text eol=lf
docker-compose.*  text eol=lf

# Windows-only files stay CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary assets — never diff / never normalize
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.avif  binary
*.ico   binary
*.svg   text eol=lf
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.eot   binary
*.pdf   binary
*.zip   binary
*.gz    binary
*.tar   binary

# Lockfiles — mark as generated so diffs collapse in GitHub UI
package-lock.json linguist-generated=true
yarn.lock         linguist-generated=true
pnpm-lock.yaml    linguist-generated=true
