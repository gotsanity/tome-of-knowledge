# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=replace-me-with-a-long-random-string
AUTH_TRUST_HOST=true

# Database (libSQL / SQLite file URL). In Docker this is set by compose.
DATABASE_URL=file:./data/tome.db

# First-boot GM seed. The GM account is created on first startup if no GM exists.
GM_USERNAME=archivist
GM_EMAIL=archivist@example.com
GM_DISPLAY_NAME=Elder Thorne
GM_PASSWORD=change-me-on-first-boot

# Host path to the CWS vault root. Read-only bind-mounted to /vault inside
# the web container by docker-compose. Override if your vault lives elsewhere.
# May also be overridden via the importer's --path flag at runtime.
VAULT_HOST_PATH=../skill-dev/world

# Container-side vault path. Defaults to /vault (the bind-mount target).
# Inside the container this is what `npm run vault:import` reads.
VAULT_PATH=/vault

# In-app feedback loop. When set, logged-in users see a "Report an issue"
# trigger in the lower-right corner that files a GitHub issue on the
# configured repo, attaching a screenshot via a commit to the
# `feedback-screenshots` orphan branch.
# GITHUB_TOKEN needs a classic PAT with `repo` scope (issues + contents write),
# or a fine-grained PAT scoped to this repo with Issues: Read/Write and
# Contents: Read/Write. Leave empty to disable the feature (the trigger will
# still capture client-side but the API returns 503).
GITHUB_TOKEN=
GITHUB_REPO=owner/tome-of-knowledge
